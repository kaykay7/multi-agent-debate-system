# LLM Provider: "ollama", "openai", "google", "anthropic", or "xai"
LLM_PROVIDER=ollama

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini settings (used when LLM_PROVIDER=google)
# Free tier available at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic settings (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# xAI/Grok settings (used when LLM_PROVIDER=xai)
XAI_API_KEY=your-xai-api-key-here

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
